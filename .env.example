# Public client configuration for DM Wingman Pro.
# Copy this file to ".env" and fill in the values for your backend.
# These are publishable/anon keys only — never put service-role keys or
# private secrets here (use the backend secrets manager for those).

VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# Optional product analytics (Phase 6). Leave blank to disable.
VITE_POSTHOG_KEY=""
VITE_POSTHOG_HOST="https://us.i.posthog.com"
VITE_CLARITY_ID=""
