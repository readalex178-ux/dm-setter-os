{
  "manifest_version": 3,
  "name": "DM Setter OS",
  "version": "1.0.0",
  "description": "AI Co-Pilot for DM Setters — Inbox, prospect insights, smart replies & notifications",
  "permissions": ["activeTab", "storage", "tabs", "notifications", "alarms"],
  "host_permissions": ["https://*.lovable.app/*", "https://*.supabase.co/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon128.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*",
        "https://www.facebook.com/*",
        "https://www.messenger.com/*",
        "https://web.whatsapp.com/*"
      ],
      "js": ["content.js"],
      "css": ["overlay.css"]
    }
  ],
  "icons": {
    "48": "icon128.png",
    "128": "icon128.png"
  }
}
