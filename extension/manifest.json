{
  "manifest_version": 3,
  "name": "DM Setter OS",
  "version": "2.0.0",
  "description": "AI co-pilot for DM setters — works on Instagram, TikTok, Twitter/X and Facebook. Syncs to your DM Setter OS dashboard.",
  "permissions": ["activeTab", "storage", "tabs", "scripting", "clipboardWrite"],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://www.tiktok.com/*",
    "https://tiktok.com/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "https://www.facebook.com/*",
    "https://www.messenger.com/*",
    "https://kwqoaqifvccxflaajrjv.supabase.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "48": "icon.png", "128": "icon128.png" }
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*",
        "https://www.tiktok.com/*",
        "https://tiktok.com/*",
        "https://twitter.com/*",
        "https://x.com/*",
        "https://www.facebook.com/*",
        "https://www.messenger.com/*"
      ],
      "js": ["platform.js", "scraper.js", "ai.js", "panel.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": { "48": "icon.png", "128": "icon128.png" }
}
