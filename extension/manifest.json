{
  "manifest_version": 3,
  "name": "DM Setter OS",
  "version": "6.0.0",
  "description": "AI co-pilot for DM setters — powered by DM Setter OS.",
  "permissions": ["activeTab", "storage", "tabs", "scripting", "clipboardWrite"],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://www.tiktok.com/*",
    "https://tiktok.com/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "https://www.facebook.com/*",
    "https://www.messenger.com/*",
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://web.whatsapp.com/*",
    "https://dm-wingman-pro.vercel.app/*",
    "https://mtvtzwxymlfgiffuvlzp.supabase.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "48": "icon.png", "128": "icon128.png" }
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*",
        "https://www.tiktok.com/*",
        "https://tiktok.com/*",
        "https://twitter.com/*",
        "https://x.com/*",
        "https://www.facebook.com/*",
        "https://www.messenger.com/*",
        "https://www.linkedin.com/*",
        "https://linkedin.com/*",
        "https://web.whatsapp.com/*"
      ],
      "js": ["scraper.js", "panel.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://dm-wingman-pro.vercel.app/*"],
      "js": ["auth-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": { "48": "icon.png", "128": "icon128.png" }
}
